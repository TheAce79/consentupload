{
  "//Comments": [
    "═══════════════════════════════════════════════════════════",
    "ConsentSync - Unified Configuration for All 3 Phases",
    "═══════════════════════════════════════════════════════════",
    "To run specific phases, set 'Enabled' to true/false",
    "The main Program.cs will orchestrate all enabled phases",
    "─────────────────────────────────────────────────────────",
    "PRE-PHASE: CSV Processing (StudentCsvProcessor)",
    "─────────────────────────────────────────────────────────"
  ],

  "CsvProcessing": {
    "InputCsvPath": "C:\\PHIS\\Abbey Landry",
    "InputCsvFileName": "immunizations.csv",
    "OutputCsvPath": "C:\\PHIS\\Abbey Landry\\Processed",
    "OutputCsvFileName": "immunizations_processed.csv",

    "SaveProgressEveryNRecords": 5,

    "DateOfBirthColumn": "Date of Birth",
    "DateFormat": "yyyy-MM-dd",
    "InputDateFormats": [
      "dd/MM/yyyy",
      "MM/dd/yyyy",
      "yyyy-MM-dd",
      "dd-MM-yyyy",
      "MM-dd-yyyy",
      "d/M/yyyy",
      "M/d/yyyy"
    ],

    "LastNameColumn": "Last Name",
    "FirstNameColumn": "First Name",
    "ClientIdColumn": "ClientId",

    "AdditionalColumns": {
      "ClientId": null,
      "IsFileRoseDefaut": false,
      "ClientIdStatus": 0,
      "BestMatch": ""
    },

    "EncodingsToTry": [
      {
        "Name": "UTF-8",
        "CodePage": "utf-8",
        "Priority": 1
      },
      {
        "Name": "UTF-8 with BOM",
        "CodePage": "utf-8",
        "UseBOM": true,
        "Priority": 2
      },
      {
        "Name": "Windows-1252 (ANSI)",
        "CodePage": "1252",
        "Priority": 3
      },
      {
        "Name": "ISO-8859-1 (Latin-1)",
        "CodePage": "iso-8859-1",
        "Priority": 4
      },
      {
        "Name": "System Default",
        "CodePage": "default",
        "Priority": 5
      }
    ]
  },

  "Phase1": {
    "_Comment": "PHASE 1: Search Client IDs on PHIS",
    "Enabled": true,
    "Description": "Search PHIS by Date of Birth and find Client IDs",

    "Processing": {
      "FilterByStatus": "NotProcessed",
      "SaveProgressEveryNRecords": 5,
      "MaxRetries": 3,
      "DelayBetweenRetriesMs": 2000
    }
  },

  "Phase2": {
    "_Comment": "PHASE 2: Download Consent Forms from Vitalite (IMPLEMENTATION PENDING)",
    "Enabled": false,
    "Description": "Download consent PDFs from Vitalite and rename to ClientID format",

    "VitaliteWebsite": {
      "LoginUrl": "https://vitalite-internal-site.ca/login",
      "SearchUrl": "https://vitalite-internal-site.ca/consents/search",
      "Username": "",
      "Password": "",
      "WaitAfterLoginSeconds": 3,
      "DownloadTimeoutSeconds": 30
    },

    "SearchCriteria": {
      "UseLastName": true,
      "UseFirstName": true,
      "UseSchool": true,
      "UseGrade": true
    },

    "Download": {
      "DownloadPath": "C:\\PHIS\\Abbey Landry\\Grade 7\\Downloads",
      "RenamedPath": "C:\\PHIS\\Abbey Landry\\Grade 7\\Done",
      "TempPath": "C:\\PHIS\\Abbey Landry\\Grade 7\\Temp",
      "MaxDownloadRetries": 3,
      "DelayBetweenDownloadsMs": 1000
    },

    "PdfProcessing": {
      "ValidateNamesBeforeRename": true,
      "SplitMultiPagePdfs": true,
      "FileRosePageThreshold": 1,
      "DebugMode": false,
      "DebugOutputDir": "C:\\PHIS\\Abbey Landry\\Grade 7\\Debug"
    },

    "Output": {
      "ValidationResultsCsv": "Validation_Results.csv",
      "UploadCsv": "Upload_to_PHIS.csv",
      "CurrentYear": "2025-2026"
    },

    "VaccineTypes": {
      "Grade7": [ "HPV9", "Tdap" ],
      "Grade9": [ "MenCACYW135" ]
    }
  },

  "Phase3": {
    "_Comment": "PHASE 3: Upload Documents to PHIS (IMPLEMENTATION PENDING)",
    "Enabled": false,
    "Description": "Upload renamed consent PDFs to PHIS client records",

    "Input": {
      "UploadCsvPath": "C:\\PHIS\\Abbey Landry\\Grade 7\\Done",
      "UploadCsvFileName": "Upload_to_PHIS.csv",
      "PdfPath": "C:\\PHIS\\Abbey Landry\\Grade 7\\Done"
    },

    "Upload": {
      "MaxUploadRetries": 3,
      "DelayBetweenUploadsMs": 2000,
      "WaitAfterUploadMs": 1500,
      "VerifyUploadSuccess": true
    },

    "FileRose": {
      "FileRoseEnabled": true,
      "FileRosePath": "C:\\PHIS\\FileRose\\DefaultFileRose.pdf",
      "UseCustomFileRosePerVaccine": false,
      "FileRoseByVaccine": {
        "HPV9": "C:\\PHIS\\FileRose\\FileRose_HPV9.pdf",
        "Tdap": "C:\\PHIS\\FileRose\\FileRose_Tdap.pdf",
        "MenCACYW135": "C:\\PHIS\\FileRose\\FileRose_MenC.pdf"
      }
    },

    "Navigation": {
      "DocumentsSectionId": "documents-tab",
      "UploadButtonId": "upload-btn",
      "DocumentTitleFieldId": "doc-title",
      "DocumentDescriptionFieldId": "doc-description"
    },

    "Output": {
      "CompletedCsvFileName": "Upload_to_PHIS_completed.csv"
    }
  },

  "PhisAutomation": {
    "_Comment": "SHARED: PHIS Automation (Phase 1 & 3)",
    "LoginUrl": "https://phisisp.gnb.ca/phsdsm/",
    "SearchUrl": "https://phisisp.gnb.ca/phsdsm/ClientWeb/pages/search/clientSearch.xhtml",

    "Authentication": {
      "Username": "",
      "Password": "",
      "ManualLoginMode": true,
      "ManualLoginWaitSeconds": 120
    },

    "Session": {
      "SessionTimeoutMinutes": 20,
      "SessionRefreshEnabled": true,
      "RefreshBufferMinutes": 2
    },

    "Timing": {
      "WebDriverWaitSeconds": 10,
      "DelayBetweenSearchesMs": 1000,
      "PageLoadDelayMs": 2000,
      "AjaxWaitMs": 1000
    },

    "ColumnHeaders": {
      "ClientId": "Client ID",
      "FirstName": "First Name",
      "LastName": "Last Name",
      "Medicare": "Health Card Number",
      "DateOfBirth": "Date of Birth"
    },

    "FuzzyMatching": {
      "Enabled": true,
      "SingleResultThreshold": 75.0,
      "MultipleResultsThreshold": 85.0,
      "ManualReviewThreshold": 70.0,
      "LastNameWeight": 0.6,
      "FirstNameWeight": 0.4,
      "IgnoreHyphensInComparison": true,
      "IgnoreSpacesInComparison": true,
      "TreatCompoundNamesAsPartialMatch": true,
      "UseMedicareNumberAsConfirmation": true,
      "MedicareNumberBoostScore": 20.0
    }
  },

  "ChromeDriver": {
    "_Comment": "SHARED: Chrome WebDriver Configuration",
    "UsePortableChrome": true,
    "PortableChromePath": "C:\\Users\\Jaabir\\Documents\\ChromeTesting\\chrome.exe",
    "ChromeDriverPath": "",
    "UseDebuggerMode": false,
    "DebuggerPort": 9222,

    "Options": {
      "StartMaximized": true,
      "DisableNotifications": true,
      "DisablePopupBlocking": true,
      "HideAutomationIndicators": true,
      "Headless": false
    },

    "Download": {
      "DefaultDownloadDirectory": "C:\\PHIS\\Downloads"
    }
  },

  "PdfExtraction": {
    "_Comment": "SHARED: PDF Processing (Phase 2)",
    "LastNameKeywords": [ "FAMILLE", "NOM", "SURNAME" ],
    "FirstNameKeywords": [ "PRÉNOM", "PRENOM", "GIVEN" ],
    "ExcludeKeywords": [ "PRÉFÉRÉ", "PREFERRED", "DATE", "SEXE", "GENDER", "SEX" ],
    "FieldLabelWords": [
      "FIRST",
      "LAST",
      "NAME",
      "PREFERRED",
      "NOM",
      "PRÉNOM",
      "PRENOM",
      "DE",
      "FAMILLE",
      "GIVEN",
      "SURNAME",
      "LEGAL",
      "GUARDIAN",
      "PARENT",
      "TEACHER",
      "HOMEROOM",
      "SCHOOL",
      "GRADE"
    ],
    "SearchRange": 15,
    "MinNameLength": 2,

    "LastNamePatterns": [
      {
        "Words": [ "LAST", "NAME" ],
        "Language": "English"
      },
      {
        "Words": [ "NOM", "DE", "FAMILLE" ],
        "Language": "French"
      },
      {
        "Words": [ "SURNAME" ],
        "Language": "English"
      },
      {
        "Words": [ "NOM" ],
        "Language": "French"
      }
    ],

    "FirstNamePatterns": [
      {
        "Words": [ "FIRST", "NAME" ],
        "Language": "English"
      },
      {
        "Words": [ "PRÉNOM" ],
        "Language": "French"
      },
      {
        "Words": [ "PRENOM" ],
        "Language": "French"
      },
      {
        "Words": [ "GIVEN", "NAME" ],
        "Language": "English"
      }
    ],

    "PreferredNamePatterns": [
      {
        "Words": [ "PREFERRED", "FIRST", "NAME" ],
        "Language": "English"
      },
      {
        "Words": [ "PRÉNOM", "PRÉFÉRÉ" ],
        "Language": "French"
      }
    ]
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "ConsentSync": "Debug"
    },
    "Console": {
      "UseColoredOutput": true,
      "ShowTimestamps": true
    },
    "File": {
      "Enabled": false,
      "LogPath": "C:\\PHIS\\Logs",
      "LogFileName": "ConsentSync_{Date}.log",
      "MaxFileSizeMB": 10,
      "RetainDays": 30
    }
  }

}