{
  "CsvProcessing": {
    "InputCsvPath": "C:\\PHIS\\Abbey Landry",
    "InputCsvFileName": "immunizations.csv",
    "OutputCsvPath": "C:\\PHIS\\Abbey Landry\\Processed",
    "OutputCsvFileName": "immunizations_processed.csv",

    "SaveProgressEveryNRecords": 1,

    "DateOfBirthColumn": "Date of Birth",
    "DateFormat": "yyyy-MM-dd",
    "InputDateFormats": [
      "dd/MM/yyyy",
      "MM/dd/yyyy",
      "yyyy-MM-dd",
      "dd-MM-yyyy",
      "MM-dd-yyyy",
      "d/M/yyyy",
      "M/d/yyyy"
    ],
    "LastNameColumn": "Last Name",
    "FirstNameColumn": "First Name",
    "ClientIdColumn": "ClientId",

    "AdditionalColumns": {
      "ClientId": null,
      "IsFileRoseDefaut": false
    },

    "EncodingsToTry": [
      {
        "Name": "UTF-8",
        "CodePage": "utf-8",
        "Priority": 1
      },
      {
        "Name": "UTF-8 with BOM",
        "CodePage": "utf-8",
        "UseBOM": true,
        "Priority": 2
      },
      {
        "Name": "Windows-1252 (ANSI)",
        "CodePage": "1252",
        "Priority": 3
      },
      {
        "Name": "ISO-8859-1 (Latin-1)",
        "CodePage": "iso-8859-1",
        "Priority": 4
      },
      {
        "Name": "System Default",
        "CodePage": "default",
        "Priority": 5
      }
    ]
  },

  "PhisAutomation": {
    "LoginUrl": "https://phisisp.gnb.ca/phsdsm/",
    "SearchUrl": "https://phisisp.gnb.ca/phsdsm/ClientWeb/pages/search/clientSearch.xhtml",

    "ColumnHeaders": {
      "ClientId": "Client ID",
      "FirstName": "First Name",
      "LastName": "Last Name",
      "Medicare": "Health Card Number"
    },

    "Username": "",
    "Password": "",
    "WebDriverWaitSeconds": 10,
    "DelayBetweenSearchesMs": 1000,
    "PageLoadDelayMs": 2000,
    "ManualLoginMode": true,
    "ManualLoginWaitSeconds": 120,

    "ChromeDriver": {
      "UsePortableChrome": true,
      "PortableChromePath": "C:\\Users\\Jaabir\\Documents\\ChromeTesting\\chrome.exe",
      "ChromeDriverPath": "",
      "UseDebuggerMode": false,
      "DebuggerPort": 9222
    },

    "FuzzyMatching": {
      "Enabled": true,
      "SingleResultThreshold": 75,
      "MultipleResultsThreshold": 85,
      "ManualReviewThreshold": 70,
      "LastNameWeight": 0.6,
      "FirstNameWeight": 0.4,
      "IgnoreHyphensInComparison": true,
      "IgnoreSpacesInComparison": true,
      "TreatCompoundNamesAsPartialMatch": true,
      "UseMedicareNumberAsConfirmation": true,
      "MedicareNumberBoostScore": 20
    }
  }
}